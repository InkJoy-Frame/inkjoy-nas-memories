# ── 导出的镜像 tar 包（最大元凶，各 ~250MB）──────────────────
*.tar

# ── 运行时挂载卷（容器内由 -v 挂载，不应打包）────────────────
images/
data/

# ── 开发 / IDE 文件 ────────────────────────────────────────────
.cursor/
.git/
.gitignore
*.md

# ── 构建脚本（容器内不需要）───────────────────────────────────
build-export*.ps1

# ── 根目录源文件图片（非 static 资源）────────────────────────
Logo*.png
